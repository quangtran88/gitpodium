#!/usr/bin/env bash
# gitpodium — rank git contributors across all branches/history of GitHub owners,
# then generate a self-contained HTML leaderboard. All artifacts land in the CURRENT
# directory (override with GITPODIUM_OUT). If ./gitpodium.config.sh exists it is sourced.
#
# Commands:
#   gitpodium run <owner>...     clone -> mailmap -> collect -> rollup -> github -> report.html
#   gitpodium clone <owner>...   clone/update repos only
#   gitpodium mailmap [clones]   (re)build the identity .mailmap
#   gitpodium collect [clones]   walk all branches -> contrib-commits.tsv
#   gitpodium rollup             tsv -> monthly.json + monthly.csv
#   gitpodium github <owner>...  GitHub PRs/reviews/issues -> github.json (Collaboration tab)
#   gitpodium report             monthly.json (+github.json) -> self-contained report.html
#   gitpodium rank [args...]     console leaderboard (see: gitpodium rank -h via report.sh header)
#
# <owner> is a GitHub org OR user. Filters: MAXCHURN / MAXFILES / DROP_BOTS (env).
# GITPODIUM_SKIP_GITHUB=1 skips the (API-based, GitHub-only) collaboration step in `run`.
set -euo pipefail
HERE="$(cd "$(dirname "$0")" && pwd)"
BIN="$HERE/bin"
[ -f "$PWD/gitpodium.config.sh" ] && . "$PWD/gitpodium.config.sh"
export GITPODIUM_OUT="${GITPODIUM_OUT:-$PWD}"
CLONES="${GITPODIUM_CLONES:-$PWD/clones}"

usage(){ sed -n '2,20p' "$0" | sed 's/^# \{0,1\}//'; }

cmd="${1:-help}"; shift || true
case "$cmd" in
  clone)   "$BIN/clone-all.sh" "$@" ;;
  mailmap) "$BIN/build-mailmap.py" "${1:-$CLONES}" ;;
  collect) "$BIN/collect.sh" "${1:-$CLONES}" ;;
  rollup)  "$BIN/rollup.sh" ;;
  github)  "$BIN/collect-github.py" "$@" ;;
  report)  "$BIN/build-report.py" "$@" ;;
  rank)    "$BIN/report.sh" "$@" ;;
  run)
    "$BIN/clone-all.sh" "$@"
    "$BIN/build-mailmap.py" "$CLONES"
    "$BIN/collect.sh" "$CLONES"
    "$BIN/rollup.sh"
    # GitHub collaboration data is best-effort: needs the API + GitHub-hosted repos,
    # and the git report must still build if it's unavailable. Drop any stale github.json
    # first so a failed run can't silently serve last run's numbers.
    if [ "${GITPODIUM_SKIP_GITHUB:-0}" = "0" ]; then
      rm -f "$GITPODIUM_OUT/github.json"
      "$BIN/collect-github.py" "$@" || echo "note: GitHub collaboration step skipped/failed — report still built from git history."
    fi
    "$BIN/build-report.py"
    echo "----------------------------------------"
    echo "done -> $GITPODIUM_OUT/report.html"
    ;;
  help|-h|--help) usage ;;
  *) echo "unknown command: $cmd" >&2; echo >&2; usage >&2; exit 2 ;;
esac
